<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/Game/GameStyleSheet.uss?fileID=7433441132597879392&amp;guid=425b8c245f03244e6a36161582fd4a92&amp;type=3#GameStyleSheet"/>
    <ui:VisualElement name="MainContainer" style="flex-grow: 1; background-color: rgb(0, 0, 0); background-image: url(&quot;project://database/Assets/Sprites/IMG_0009.jpeg?fileID=2800000&amp;guid=e270c141e14c8477da65ff734b44df46&amp;type=3#IMG_0009&quot;);">
        <ui:VisualElement name="ResourceContainer" class="header resourcecontainer" style="flex-grow: 1; -unity-background-image-tint-color: rgb(0, 0, 0); background-color: rgb(108, 31, 31); aspect-ratio: auto; max-height: 75px;">
            <ui:VisualElement name="Resource" class="resource" style="flex-grow: 1; flex-direction: row;">
                <ui:Image name="croinsSprite" source="project://database/Assets/UI/UI%20Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=4154780841294389669&amp;guid=e6afc6c91105246ca836ef82e02648ad&amp;type=3#arrow-down" class="resourceimage resourcetext resourceImage" style="width: 73px; height: 52px; margin-right: 0;"/>
                <ui:Label text="NUMBER" name="croins" class="resourcetext" style="width: 135px; -unity-text-outline-color: rgb(0, 0, 0);"/>
                <ui:Image name="rSprite" source="project://database/Assets/UI/UI%20Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=4154780841294389669&amp;guid=e6afc6c91105246ca836ef82e02648ad&amp;type=3#arrow-down" class="resourceimage resourcetext resourceImage" style="width: 73px; height: 52px; margin-right: 0;"/>
                <ui:Label text="NUMBER" name="rCreatures" class="resourcetext" style="width: 135px; -unity-text-outline-color: rgb(0, 0, 0);"/>
                <ui:Image name="bSprite" source="project://database/Assets/UI/UI%20Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=4154780841294389669&amp;guid=e6afc6c91105246ca836ef82e02648ad&amp;type=3#arrow-down" class="resourceimage resourcetext resourceImage" style="width: 73px; height: 52px; margin-right: 0;"/>
                <ui:Label text="NUMBER" name="bCreatures" class="resourcetext" style="width: 138px; -unity-text-outline-color: rgb(0, 0, 0);"/>
                <ui:Image name="gSprite" source="project://database/Assets/UI/UI%20Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=4154780841294389669&amp;guid=e6afc6c91105246ca836ef82e02648ad&amp;type=3#arrow-down" class="resourceimage resourcetext resourceImage" style="-unity-text-align: upper-center; width: 60px; height: 49px; margin-right: -1px; margin-left: 0;"/>
                <ui:Label text="NUMBER" name="gCreatures" class="resourcetext" style="width: 123px; -unity-text-outline-color: rgb(0, 0, 0);"/>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="VisualElement" style="flex-grow: 1;">
            <ui:VisualElement name="GameContainer" class="container" style="flex-grow: 1; background-color: rgba(121, 0, 125, 0);">
                <ui:VisualElement name="UpgradesContainer" class="subcontainers" style="flex-grow: 1; align-items: center; align-self: auto; align-content: auto; background-color: rgb(153, 0, 255); justify-content: flex-start; flex-direction: column; width: 38px;">
                    <ui:VisualElement name="Upgrade1" class="UpgradeContainer" style="width: auto;">
                        <ui:Image source="project://database/Assets/Sprites/Pokebola-pokeball-png-0.png?fileID=2800000&amp;guid=56c0555a482464832946e3e40b701c92&amp;type=3#Pokebola-pokeball-png-0" name="Upgrade1Sprite" class="upgrade" style="width: 62px;"/>
                        <ui:Label text="Catch Training" name="Upgrade1Name" class="upgrade" style="width: 104px;"/>
                        <ui:Label text="0/0" name="Upgrade1Status" class="upgrade" style="width: 41px;"/>
