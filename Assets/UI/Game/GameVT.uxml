                    <ui:VisualElement name="UpgradeContainer" class="UpgradeContainer" style="flex-grow: 0; flex-basis: auto; flex-direction: row; flex-wrap: nowrap; flex-shrink: 0; align-self: auto; justify-content: center; align-items: flex-start; margin-top: 28px; width: auto;">
                        <ui:Image source="project://database/Assets/Sprites/Pokebola-pokeball-png-0.png?fileID=2800000&amp;guid=56c0555a482464832946e3e40b701c92&amp;type=3#Pokebola-pokeball-png-0" name="" class="upgrade" style="width: 63px;"/>
                        <ui:Label text="Catch Training" class="upgrade" style="width: 104px;"/>
                        <ui:Label text="0/0" class="upgrade" style="width: 41px;"/>
                        <ui:Button text="Upgrade&#10;" class="upgrade" style="background-color: rgb(255, 255, 255); width: 103px; font-size: 14px; -unity-text-align: middle-center; text-overflow: ellipsis;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="CreaturePortrait" class="subcontainers" style="flex-grow: 1; background-color: rgb(0, 0, 0); cursor: url(&quot;project://database/Assets/UI/UI%20Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=4154780841294389669&amp;guid=e6afc6c91105246ca836ef82e02648ad&amp;type=3#arrow-down&quot;); font-size: 15px; flex-direction: column; flex-wrap: nowrap; width: 115px;">
                    <ui:ProgressBar value="22" title="Catch Progress" name="CatchProgress"/>
